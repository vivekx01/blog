---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import BackToPrev from "@components/BackToPrev.astro";
import { BLOG } from "@consts";

const allPosts = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .filter(post => post.slug.startsWith("technical/"));

const categoryMap = new Map<string, { count: number; latest: Date }>();

for (const post of allPosts) {
  const parts = post.slug.split("/");
  if (parts.length >= 3) {
    const slug = parts[1];
    const existing = categoryMap.get(slug);
    if (!existing || post.data.date > existing.latest) {
      categoryMap.set(slug, {
        count: (existing?.count ?? 0) + 1,
        latest: existing ? (post.data.date > existing.latest ? post.data.date : existing.latest) : post.data.date,
      });
    } else {
      existing.count++;
    }
  }
}

const categories = Array.from(categoryMap.entries())
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([slug, { count, latest }]) => ({
    slug,
    name: slug.charAt(0).toUpperCase() + slug.slice(1).replace(/-/g, " "),
    count,
    latest: latest.toLocaleDateString("en-US", { year: "numeric", month: "short" }),
  }));
---

<PageLayout title={BLOG.TITLE} description={BLOG.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <div class="animate">
        <BackToPrev href={import.meta.env.BASE_URL}>
          Back
        </BackToPrev>
      </div>
      <div class="animate font-semibold text-black dark:text-white">
        Technical Writings
      </div>
      <ul class="flex flex-col gap-3">
        {categories.map(({ slug, name, count, latest }) => (
          <li class="animate">
            <a
              href={`/blog/technical/${slug}`}
              class="relative group flex items-center justify-between py-3 px-4 pr-10 rounded-lg border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out"
            >
              <div class="flex flex-col gap-0.5">
                <span class="font-semibold">{name}</span>
                <span class="text-xs text-black/40 dark:text-white/40">
                  {count} article{count !== 1 ? "s" : ""} &middot; latest {latest}
                </span>
              </div>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                class="absolute top-1/2 right-2 -translate-y-1/2 size-5 stroke-2 fill-none stroke-current"
              >
                <line x1="5" y1="12" x2="19" y2="12" class="translate-x-3 group-hover:translate-x-0 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 ease-in-out" />
                <polyline points="12 5 19 12 12 19" class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-300 ease-in-out" />
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </Container>
</PageLayout>
