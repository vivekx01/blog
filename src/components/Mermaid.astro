---
interface Props {
  code: string;
}
const { code } = Astro.props;
---

<div class="mermaid-diagram-wrapper relative group my-4">
  <div class="mermaid-diagram w-full overflow-x-auto rounded-lg bg-white px-2 py-3 cursor-zoom-in" data-expandable>
    <pre class="mermaid mermaid-fit bg-white">{code}</pre>
  </div>
  <button
    type="button"
    class="mermaid-expand-btn absolute top-2 right-2 opacity-40 group-hover:opacity-100 transition-opacity bg-white rounded p-1.5 border border-gray-200 text-gray-500 hover:text-gray-800 hover:bg-gray-50"
    aria-label="Expand diagram"
    title="Expand"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
    </svg>
  </button>
</div>

<style>
  .mermaid-diagram .mermaid-fit {
    padding-left: 4px;
  }
  .mermaid-diagram .mermaid-fit svg {
    max-width: 100%;
    min-height: 340px;
    height: auto;
  }
  #mermaid-modal .mermaid-modal-svg svg {
    width: 100%;
    height: auto;
    min-height: 500px;
  }
</style>

<script>
  import mermaid from "mermaid";

  mermaid.initialize({
    startOnLoad: false,
    theme: "base",
    securityLevel: "loose",
    flowchart: {
      padding: 24,
      diagramPadding: 24,
    },
    sequence: {
      diagramMarginX: 16,
      diagramMarginY: 8,
      boxMargin: 8,
    },
    themeVariables: {
      background: "#f4f4f5",
      primaryColor: "#e0f2fe",
      primaryTextColor: "#18181b",
      primaryBorderColor: "#0ea5e9",
      lineColor: "#3f3f46",
      secondaryColor: "#f4f4f5",
      tertiaryColor: "#ffffff",
      textColor: "#18181b",
      mainBkg: "#e0f2fe",
      nodeBorder: "#0ea5e9",
      clusterBkg: "#f4f4f5",
      titleColor: "#18181b",
      edgeLabelBackground: "#ffffff",
      nodeTextColor: "#18181b",
    },
  });

  const VIEWBOX_PADDING = 24;
  const FOREIGN_OBJECT_WIDTH_PADDING = 24;
  const FOREIGN_OBJECT_HEIGHT_PADDING = 8;

  function postProcessSvg(svgString: string) {
    const parser = new DOMParser();
    const doc = parser.parseFromString(svgString, "image/svg+xml");
    const svg = doc.querySelector("svg");

    const viewBox = svg?.getAttribute("viewBox");
    if (svg && viewBox) {
      const [x, y, w, h] = viewBox.split(/\s+/).map(Number);
      (svg as SVGElement).setAttribute("viewBox", [x - VIEWBOX_PADDING, y - VIEWBOX_PADDING, w + 2 * VIEWBOX_PADDING, h + 2 * VIEWBOX_PADDING].join(" "));
    }

    doc.querySelectorAll("foreignObject").forEach((fo) => {
      const w = parseFloat(fo.getAttribute("width") ?? "");
      const h = parseFloat(fo.getAttribute("height") ?? "");
      if (!Number.isNaN(w)) fo.setAttribute("width", String(w + FOREIGN_OBJECT_WIDTH_PADDING));
      if (!Number.isNaN(h)) fo.setAttribute("height", String(h + FOREIGN_OBJECT_HEIGHT_PADDING));
    });

    return new XMLSerializer().serializeToString(doc);
  }

  function ensureModal() {
    if (document.getElementById("mermaid-modal")) return;

    const modal = document.createElement("div");
    modal.id = "mermaid-modal";
    modal.setAttribute("role", "dialog");
    modal.setAttribute("aria-modal", "true");
    modal.style.cssText = "display:none;position:fixed;inset:0;z-index:100;background:rgba(0,0,0,0.8);align-items:center;justify-content:center;padding:1rem;";
    modal.innerHTML = `
      <div style="position:relative;background:#fff;border-radius:0.75rem;width:100%;max-width:72rem;max-height:90vh;overflow:auto;padding:2rem;">
        <button id="mermaid-modal-close" aria-label="Close" style="position:absolute;top:0.75rem;right:0.75rem;width:2rem;height:2rem;display:flex;align-items:center;justify-content:center;border-radius:9999px;background:#f3f4f6;border:none;cursor:pointer;color:#6b7280;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
        <div class="mermaid-modal-svg" style="display:flex;align-items:center;justify-content:center;"></div>
      </div>
    `;
    document.body.appendChild(modal);

    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeMermaidModal();
    });
    document.getElementById("mermaid-modal-close")?.addEventListener("click", closeMermaidModal);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeMermaidModal();
    });
  }

  function openMermaidModal(svgHtml: string) {
    ensureModal();
    const modal = document.getElementById("mermaid-modal")!;
    const content = modal.querySelector(".mermaid-modal-svg")!;
    content.innerHTML = svgHtml;
    const scrollY = window.scrollY;
    document.body.style.position = "fixed";
    document.body.style.top = `-${scrollY}px`;
    document.body.style.width = "100%";
    modal.style.display = "flex";
  }

  function closeMermaidModal() {
    const modal = document.getElementById("mermaid-modal");
    if (!modal) return;
    modal.style.display = "none";
    const scrollY = parseInt(document.body.style.top || "0") * -1;
    document.body.style.position = "";
    document.body.style.top = "";
    document.body.style.width = "";
    window.scrollTo(0, scrollY);
  }

  function setupExpandButtons() {
    document.querySelectorAll(".mermaid-diagram[data-expandable]").forEach((diagram) => {
      if ((diagram as HTMLElement).dataset.expandSetup) return;
      (diagram as HTMLElement).dataset.expandSetup = "1";

      const wrapper = diagram.closest(".mermaid-diagram-wrapper");
      const btn = wrapper?.querySelector(".mermaid-expand-btn");

      function expand() {
        const svg = diagram.querySelector("svg");
        if (!svg) return;
        openMermaidModal(svg.outerHTML);
      }

      diagram.addEventListener("click", expand);
      btn?.addEventListener("click", (e) => {
        e.stopPropagation();
        expand();
      });
    });
  }

  function renderMermaid() {
    ensureModal();
    document.querySelectorAll(".mermaid-diagram pre.mermaid").forEach((node) => {
      const code = node.textContent?.trim();
      if (!code || code.startsWith("<")) return;
      const id = "mermaid-" + Math.random().toString(36).slice(2, 11);
      mermaid.render(id, code).then(({ svg }) => {
        node.innerHTML = postProcessSvg(svg);
        setupExpandButtons();
      }).catch((err) => {
        console.error("Mermaid render error:", err);
        node.innerHTML = `<pre class="text-left text-sm text-red-600 dark:text-red-400">${err.message ?? "Diagram failed to render."}</pre>`;
      });
    });
  }

  document.addEventListener("astro:after-swap", renderMermaid);

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", renderMermaid);
  } else {
    renderMermaid();
  }
</script>
